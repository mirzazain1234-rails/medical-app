<h1 class="section-title text-center my-5">Products</h1>

<div class="container">
  <div class="row gy-4">
    <% @products.each do |product| %>
      <div class="col-xl-3 col-lg-4 col-md-6">
        <div class="product-card p-4 border rounded shadow-sm h-100 d-flex flex-column justify-content-between">
          <h3 class="product-name"><%= product.name %></h3>
          <p class="product-description"><%= product.description %></p>
          <h4 class="product-price">$<%= number_with_precision(product.price, precision: 2) %></h4>

          <div class="btn-group mt-3">
            <%= link_to 'Edit', edit_product_path(product), class: "btn btn-primary btn-sm" %>
            <%= link_to 'Delete', product_path(product), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center my-5">
    <%= link_to 'Add New Product', new_product_path, class: "btn btn-success btn-lg" %>
  </div>
</div>
